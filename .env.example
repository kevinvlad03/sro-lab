# Supabase project credentials.
# Get these from https://app.supabase.com → your project → Settings → API.
# Copy this file to .env.local and fill in the real values (.env.local is gitignored).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public URL of this app — used to build links in emails.
# Local dev: http://localhost:3000
# Production: e.g. https://sro-lab.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend transactional email (https://resend.com).
# Without RESEND_API_KEY, emails are silently skipped — the app still
# works, just no email. Get a key from the Resend dashboard.
RESEND_API_KEY=

# Verified "from" address. Leave empty to use Resend's sandbox
# (onboarding@resend.dev). The sandbox only delivers to the email tied
# to your Resend account, which is fine for testing. Once you verify a
# domain, set this to e.g. "SRO Lab <notifications@yourdomain.com>".
RESEND_FROM_EMAIL=
